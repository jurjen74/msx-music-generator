# Copy to .env and fill in your key:  cp .env.example .env
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# PORT=5173
# MSX_MODEL=claude-sonnet-4-6

# Optional: path to MSXgl's MSXzip binary. When set (and the file exists), the app
# enables a "Download .lvgm" button that converts to compact, MSX-optimized lVGM
# (~75-85% smaller). Use MSXzip.exe on Windows. Leave unset to disable the feature.
# MSXZIP=/path/to/MSXgl/tools/MSXtk/bin/MSXzip
